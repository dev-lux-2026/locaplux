generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model User {
  id                         String                     @id @default(cuid())
  name                       String?
  email                      String?                    @unique
  password                   String?
  emailVerified              DateTime?
  image                      String?
  role                       Role                       @default(user)
  status                     PartnerStatus              @default(pending)
  avatar                     String?
  address                    String?
  website                    String?
  description                String?
  deliveryRadius             Int?
  stripeAccountId            String?
  slug                       String?                    @unique
  folderUrl                  String?
  folderUpdatedAt            DateTime?
  freeProductLimit           Int?                       @default(0)
  freeUntil                  DateTime?
  commissionRate             Float?
  freeDaysLimit              Int?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deletedAt                  DateTime?
  city                       String?
  company                    String?
  country                    String?
  firstName                  String?
  lastName                   String?
  number                     String?
  phone                      String?
  phonePrefix                String?
  postal                     String?
  publicName                 String?
  street                     String?
  vat                        String?
  freeItemsLimit             Int?
  freeItemsUsed              Int?
  offerId                    String?
  bannerUrl                  String?
  averageResponseTime        Int?
  responseTimeUpdatedAt      DateTime?                  @default(now()) @db.Timestamptz(6)
  preferredLanguage          String?                    @default("fr")
  acceptedTermsAt            DateTime?                  @default(now()) @db.Timestamp(6)
  acceptedPartnerTermsAt     DateTime?                  @db.Timestamp(6)
  termsVersion               Int?                       @default(1)
  partnerTermsVersion        Int?                       @default(1)
  vatCheckFailed             Boolean                    @default(false)
  delivery_price_per_km      Decimal?                   @db.Decimal
  delivery_min_price         Decimal?                   @db.Decimal
  delivery_max_price         Decimal?                   @db.Decimal
  delivery_max_km            Decimal?                   @db.Decimal
  delivery_allowed_countries String[]
  default_pickup_available   Boolean?                   @default(true)
  default_delivery_available Boolean?                   @default(true)
  lat                        Float?
  lng                        Float?
  addresses                  Address[]
  adminLogs                  AdminLog[]                 @relation("AdminLogs")
  partnerLogs                AdminLog[]                 @relation("PartnerLogs")
  boosts                     Boost[]
  commissions                Commission[]
  conversationsAsBuyer       Conversation[]             @relation("ConversationBuyer")
  conversationsAsPartner     Conversation[]             @relation("ConversationPartner")
  invoices                   Invoice[]
  messages                   Message[]                  @relation("MessageSender")
  ordersAsPartner            Order[]                    @relation("OrderPartner")
  ordersAsBuyer              Order[]                    @relation("OrderBuyer")
  partnerApplication         PartnerApplication?
  products                   Product[]
  wishlists                  Wishlist[]
  ProductValidationHistory   ProductValidationHistory[]
  buyerQuestions             Question[]                 @relation("BuyerQuestions")
  partnerQuestions           Question[]                 @relation("PartnerQuestions")
  supportTickets             SupportTicket[]
  offer                      Offer?                     @relation(fields: [offerId], references: [id])
  passwordResetTokens        PasswordResetToken[]

  @@schema("public")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  token     String    @unique
  type      String    @default("partner_activation")
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("passwordResetToken")
  @@schema("public")
}

model Category {
  id        String    @id(map: "categories_pkey")
  name      String
  name_fr   String?
  name_en   String?
  name_lu   String?
  root      String
  parent    String
  active    Boolean   @default(true)
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  products  Product[]

  @@schema("public")
}

model Product {
  id                 String                     @id @default(cuid())
  name               String
  slug               String                     @unique
  description        String?
  stock              Int                        @default(0)
  images             String[]                   @default([])
  active             Boolean                    @default(true)
  categoryId         String?
  partnerId          String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  status             ProductStatus              @default(pending)
  isFree             Boolean                    @default(false)
  prix_normal        Int?
  prix_locaplux      Int?
  prix_achat         Int?
  condition          String?                    @default("new")
  damage_type        String?
  damage_description String?
  pickup_available   Boolean?                   @default(true)
  delivery_available Boolean?                   @default(false)
  Boost              Boost[]
  orderItems         OrderItem[]
  category           Category?                  @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  partner            User                       @relation(fields: [partnerId], references: [id])
  validationHistory  ProductValidationHistory[]
  questions          Question[]
  wishlists          Wishlist[]

  @@schema("public")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@schema("public")
}

model Boost {
  id        String   @id @default(cuid())
  title     String
  price     Int
  duration  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partnerId String?
  productId String?
  partner   User?    @relation(fields: [partnerId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])

  @@schema("public")
}

model PartnerApplication {
  id           String   @id @default(cuid())
  userId       String   @unique
  company      String
  email        String
  phone        String?
  address      String?
  website      String?
  description  String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  adminComment String?
  documents    String[] @default([])
  user         User     @relation(fields: [userId], references: [id])

  @@schema("public")
}

model Order {
  id               String            @id @db.Uuid
  status           OrderStatus       @default(pending)
  total            Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  paidAt           DateTime?
  paymentIntentId  String?
  userId           String
  partnerId        String
  city             String?
  country          String?
  number           String?
  postal           String?
  street           String?
  commissionAmount Float?
  commissionRate   Float?
  partnerAmount    Float?
  commission       Commission?
  conversation     Conversation?
  partner          User              @relation("OrderPartner", fields: [partnerId], references: [id])
  user             User              @relation("OrderBuyer", fields: [userId], references: [id])
  items            OrderItem[]
  partner_reviews  partner_reviews[]

  @@schema("public")
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Int
  productId String
  orderId   String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "orderitem_order_fk")

  @@schema("public")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  partnerId String
  action    String
  comment   String?
  createdAt DateTime @default(now())
  admin     User     @relation("AdminLogs", fields: [adminId], references: [id])
  partner   User     @relation("PartnerLogs", fields: [partnerId], references: [id])

  @@schema("public")
}

model Question {
  id         String         @id @default(cuid())
  productId  String
  buyerId    String
  partnerId  String
  message    String
  answer     String?
  createdAt  DateTime       @default(now())
  answeredAt DateTime?
  buyer      User           @relation("BuyerQuestions", fields: [buyerId], references: [id])
  partner    User           @relation("PartnerQuestions", fields: [partnerId], references: [id])
  product    Product        @relation(fields: [productId], references: [id])
  files      QuestionFile[]

  @@schema("public")
}

model QuestionFile {
  id         String   @id @default(cuid())
  questionId String
  url        String
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id])

  @@schema("public")
}

model Conversation {
  id        String    @id @default(cuid())
  orderId   String    @unique @db.Uuid
  buyerId   String
  partnerId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  buyer     User      @relation("ConversationBuyer", fields: [buyerId], references: [id])
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  partner   User      @relation("ConversationPartner", fields: [partnerId], references: [id])
  messages  Message[]

  @@schema("public")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String?
  image          String?
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])

  @@schema("public")
}

model SupportTicket {
  id          String           @id @default(cuid())
  type        String
  subject     String
  description String
  priority    String
  status      String
  authorId    String
  assignedTo  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  messages    SupportMessage[]
  author      User             @relation(fields: [authorId], references: [id])

  @@schema("public")
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  from      String
  content   String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])

  @@schema("public")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model Offer {
  id                String   @id
  name              String
  commissionRate    Float
  subscriptionPrice Float
  boostDiscount     Float
  freeItemsLimit    Int
  features          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  partners          User[]

  @@schema("public")
}

model Commission {
  id               String   @id @default(cuid())
  orderId          String   @unique @db.Uuid
  partnerId        String
  commissionRate   Float
  commissionAmount Float
  createdAt        DateTime @default(now())
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  partner          User     @relation(fields: [partnerId], references: [id])

  @@schema("public")
}

model Invoice {
  id          String      @id @default(cuid())
  partnerId   String
  type        InvoiceType
  amount      Float
  vat         Float
  total       Float
  periodStart DateTime?
  periodEnd   DateTime?
  createdAt   DateTime    @default(now())
  paid        Boolean     @default(true)
  metadata    Json?
  partner     User        @relation(fields: [partnerId], references: [id])

  @@schema("public")
}

model partner_reviews {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id String   @db.Uuid
  buyer_id   String   @db.Uuid
  order_id   String   @db.Uuid
  rating     Int
  comment    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  Order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "partner_reviews_order_fk")
  users      users    @relation(fields: [partner_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "partner_reviews_partner_fk")

  @@unique([order_id, buyer_id], map: "partner_reviews_unique_review_per_order")
  @@schema("public")
}

model ProductValidationHistory {
  id        String    @id @default(dbgenerated("gen_random_uuid()"))
  productId String
  adminId   String
  action    String
  reason    String?
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User      User      @relation(fields: [adminId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "pvh_admin_fk")

  @@schema("public")
}

model Address {
  id      String  @id @default(cuid())
  userId  String
  type    String
  street  String
  number  String?
  zip     String
  city    String
  country String
  phone   String?
  user    User    @relation(fields: [userId], references: [id])

  @@schema("public")
}

